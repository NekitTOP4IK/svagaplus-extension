{
  "manifest_version": 3,
  "name": "Tribute Alerts Twitch Extension",
  "version": "__VERSION__",
  "description": "Расширение для сервиса Tribute Alerts. Позволяет чатерам с подпиской получить значок подписчика в чате! Made for Olesha with love <3",
  "permissions": [
    "storage",
    "activeTab",
    "identity",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "*://__BACKEND_HOST__/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.twitch.tv/*"
      ],
      "js": [
        "src/shared/config.js",
        "src/tribute-alerts/content/socket.io.js",
        "src/tribute-alerts/content/core.js",
        "src/tribute-alerts/content/twitch.js",
        "src/tribute-alerts/content/seventv.js",
        "src/tribute-alerts/content/usercard.js",
        "src/tribute-alerts/content/observer.js",
        "src/app/content.js"
      ],
      "css": [
        "src/tribute-alerts/content/styles.css"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "src/tribute-alerts/popup/popup.html",
    "default_icon": {
      "64": "icons/icon64.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*"
      ],
      "matches": [
        "*://*.twitch.tv/*"
      ]
    }
  ],
  "icons": {
    "64": "icons/icon64.png"
  },
  "background": {
    "service_worker": "src/app/background.js"
  }
}
