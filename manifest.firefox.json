{
  "manifest_version": 3,
  "name": "Свага+",
  "version": "__VERSION__",
  "description": "Расширение Свага+ для Twitch: только для тех, кто хочет быть на лютой СВАГЕ.",
  "browser_specific_settings": {
    "gecko": {
      "id": "tributealerts@nekittop4ik.qzz.io",
      "update_url": "__UPDATE_URL__"
    }
  },
  "permissions": [
    "storage",
    "identity",
    "tabs"
  ],
  "host_permissions": [
    "__BACKEND_URL__/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.twitch.tv/*"
      ],
      "js": [
        "src/vendor/socket.io.js",
        "src/app/content.js"
      ],
      "css": [
        "src/features/tribute-badges/styles.css"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "64": "icons/icon64.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*",
        "src/app/viewer-auth-callback.html"
      ],
      "matches": [
        "*://*.twitch.tv/*",
        "__FRONTEND_URL__/*"
      ]
    }
  ],
  "icons": {
    "64": "icons/icon64.png"
  },
  "background": {
    "scripts": ["src/app/background-firefox.js"]
  }
}
