{
  "name": "svagaplus-extension",
  "version": "1.0.6",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "build:firefox": "webpack --config webpack.config.js --env firefox",
    "build:prod": "webpack --config webpack.config.js --env prod && node scripts/package-chrome-prod.cjs",
    "build:prod:firefox": "webpack --config webpack.config.js --env prod --env firefox",
    "build:all": "npm run build && npm run build:firefox",
    "watch": "webpack --watch --config webpack.config.js",
    "watch:firefox": "webpack --watch --config webpack.config.js --env firefox",
    "typecheck": "tsc --noEmit",
    "test:cooldown": "tsc --module commonjs --moduleResolution node --outDir dist-types && node test/request-cooldown.test.js && node test/api-failure-cooldown.test.js",
    "test:dom": "tsc --module commonjs --moduleResolution node --outDir dist-types && node test/tribute-dom-stability.test.js && node test/social-rating-dom-stability.test.js && node test/tribute-force-batch.test.js"
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/firefox-webext-browser": "^120.0.0",
    "@types/webextension-polyfill": "^0.12.5",
    "copy-webpack-plugin": "^12.0.2",
    "jsdom": "^29.1.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.3",
    "webpack": "^5.96.1",
    "webpack-cli": "^5.1.4"
  },
  "packageManager": "pnpm@10.13.1+sha512.37ebf1a5c7a30d5fabe0c5df44ee8da4c965ca0c5af3dbab28c3a1681b70a256218d05c81c9c0dcf767ef6b8551eb5b960042b9ed4300c59242336377e01cfad"
}
